# DATABASE
# Supabase connection URI (must use postgresql+asyncpg:// for async drivers)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:54323/postgres

# SECURITY
JWT_SECRET_KEY=replace_this_with_a_secure_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OTP
# Secret key used to sign and verify OTP hashes
OTP_SECRET_KEY=another_secure_random_string_for_otp

# APP SETTINGS
PROJECT_NAME="Cognitive Assessment Platform (CAP) API"
VERSION=2.5.0-LTS
ENV=development

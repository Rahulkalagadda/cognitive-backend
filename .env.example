# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres

# Security Settings
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=replace_this_with_a_secure_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OTP Settings
OTP_SECRET_KEY=another_secure_random_string_for_otp

# Application Configuration
PROJECT_NAME="Cognitive Assessment Platform (CAP) API"
VERSION=2.5.0-LTS
ENV=development
FRONTEND_URL=http://localhost:3000

# CORS Origins (Comma-separated list or JSON array of strings)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://cognitive-function-by-drm.vercel.app

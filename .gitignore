#   For a library or app, you might want to share your .python-version.
#   For an executable, it's often better to check it in.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms, you may let them generate their own lock file.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is database of dependencies, usually recommended to inherit.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is database of dependencies, usually recommended to inherit.
# pdm.lock

